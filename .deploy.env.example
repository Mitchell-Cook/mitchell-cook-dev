# Copy to .deploy.env (which is gitignored) and fill in.
# Keeps host/user/email out of the committed, public repo.

DEPLOY_HOST=droplet          # ssh alias (from ~/.ssh/config) or the droplet's IP
DEPLOY_USER=your-ssh-user    # the non-root login user on the droplet
ADMIN_EMAIL=you@example.com  # only used by provision.sh (Let's Encrypt)
DOMAIN=mitchellcook.dev
